#!/bin/sh
# Sharp - block commits that contain secrets. Prefers gitleaks; falls back to a
# minimal, high-confidence, zero-dependency scan so it works everywhere.
root=$(git rev-parse --show-toplevel)
staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner -c "$root/.gitleaks.toml" \
    || { echo "pre-commit: gitleaks flagged a secret. Commit blocked."; exit 1; }
  echo "pre-commit: gitleaks clean"; exit 0
fi

fail=0
# sensitive filenames
if echo "$staged" | grep -iE '(^|/)\.env($|\.)|\.devkey|\.session|(^|/)id_rsa|\.pem$|\.key$|\.db$'; then
  echo "pre-commit: sensitive file staged (above)."; fail=1
fi
# secret content in staged text files (scan the staged blob, not the worktree)
for f in $staged; do
  [ -f "$f" ] || continue
  case "$f" in *.png|*.jpg|*.jpeg|*.gif|*.ico|*.webp|*.pdf|.githooks/*|.gitleaks.toml|.github/*) continue ;; esac
  if git show ":$f" 2>/dev/null | grep -nEI -- '-----BEGIN [A-Z ]*PRIVATE KEY|gh[posru]_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{30,}|sk-[A-Za-z0-9]{20,}|\[[0-9]{1,3}(,[0-9]{1,3}){47,}\]'; then
    echo "pre-commit: possible secret in $f (above)."; fail=1
  fi
done
[ "$fail" -eq 0 ] && { echo "pre-commit secret-scan: clean"; exit 0; }
echo "pre-commit: COMMIT BLOCKED - remove the secret or add the file to .gitignore."
exit 1
